# Copy this file to .env and fill in your API keys
# NEVER commit the .env file to git

# OpenAlex (free, register at https://openalex.org)
OPENALEX_EMAIL=your_email@example.com

# NCBI/PubMed E-utilities (free, register at https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=your_ncbi_api_key

# Semantic Scholar (free, register at https://www.semanticscholar.org/product/api)
S2_API_KEY=your_semantic_scholar_key

# Unpaywall (uses email as identifier)
UNPAYWALL_EMAIL=your_email@example.com
